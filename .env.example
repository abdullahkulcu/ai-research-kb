# Hepsi opsiyoneldir. Boş bırakılan her şey için ilgili özellik sessizce atlanır.

# LLM sağlayıcı (çelişki adayı tespiti, acceptance criteria, diff özeti için).
# config.yaml içinde llm.provider: "anthropic" olarak ayarlanmadıkça kullanılmaz.
ANTHROPIC_API_KEY=

# ClickUp push (web panel, Faz 2). Ayrıca config.yaml'da clickup.list_id
# gerekir. Boş bırakılırsa gerçek push 400 döner; dry-run bunları gerektirmez.
CLICKUP_API_TOKEN=

# Web panel (opsiyonel): `ai-research-kb serve` bunu gerektirir, CLI'nin geri
# kalanı etkilenmez. Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
WEB_JWT_SECRET=
